# Evolve8 Enterprises — environment variables
# Copy to .env.local and fill in.

# Mailchimp (opt-in newsletter only — not for cold outreach)
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_DC=us21

# Resend (transactional email — Public Action confirmations, simulator reports)
RESEND_API_KEY=

# Public Action Network database (Postgres / Supabase)
DATABASE_URL=

# Site URL (used for OG / canonical)
NEXT_PUBLIC_SITE_URL=https://evolve8enterprises.com

# Forwarding addresses (Cloudflare Email Routing → reyaporche@gmail.com)
PRESS_INBOX=press@evolve8enterprises.com
DONATE_INBOX=donate@evolve8enterprises.com
FOUNDER_INBOX=founder@evolve8enterprises.com
HELLO_INBOX=hello@evolve8enterprises.com
